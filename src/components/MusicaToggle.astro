---
import { contenido } from '../data/contenido.js';
const { musica } = contenido;
const tieneMusica = Boolean(musica.archivo);
const src = tieneMusica ? `${import.meta.env.BASE_URL}/${musica.archivo}` : '';
---

{
  tieneMusica && (
    <>
      <audio id="bg-music" src={src} loop preload="auto"></audio>
      <button class="music-btn" id="music-btn" aria-label="Silenciar o activar música" aria-pressed="true">
        <span class="music-btn__on" aria-hidden="true">♫</span>
        <span class="music-btn__bars" aria-hidden="true"><i></i><i></i><i></i></span>
      </button>
    </>
  )
}

<style>
  .music-btn {
    position: fixed;
    bottom: 1.2rem;
    right: 1.2rem;
    z-index: 70;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: 1px solid rgba(247, 240, 234, 0.25);
    background: rgba(26, 20, 24, 0.7);
    backdrop-filter: blur(8px);
    color: var(--cream);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .music-btn:hover { transform: scale(1.08); background: rgba(201, 123, 148, 0.4); }
  .music-btn__on { display: none; font-size: 1.3rem; }
  .music-btn.is-muted .music-btn__on { display: block; opacity: 0.5; }
  .music-btn.is-muted .music-btn__bars { display: none; }

  .music-btn__bars {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 18px;
  }
  .music-btn__bars i {
    width: 3px;
    background: var(--rose);
    border-radius: 2px;
    animation: eq 0.9s ease-in-out infinite;
  }
  .music-btn__bars i:nth-child(1) { height: 8px; animation-delay: 0s; }
  .music-btn__bars i:nth-child(2) { height: 16px; animation-delay: 0.2s; }
  .music-btn__bars i:nth-child(3) { height: 11px; animation-delay: 0.4s; }
  @keyframes eq {
    0%, 100% { transform: scaleY(0.5); }
    50% { transform: scaleY(1); }
  }
</style>

<script>
  const audio = document.getElementById('bg-music') as HTMLAudioElement | null;
  const btn = document.getElementById('music-btn');
  if (audio && btn) {
    audio.volume = 0.55;
    let playing = false;

    function start() {
      audio!.play().then(() => {
        playing = true;
        btn!.classList.remove('is-muted');
        btn!.setAttribute('aria-pressed', 'true');
      }).catch(() => {
        // El navegador bloqueó el autoplay; queda en silencio hasta tocar el botón.
        btn!.classList.add('is-muted');
        btn!.setAttribute('aria-pressed', 'false');
      });
    }

    // Empieza cuando se abre el sobre (gesto del usuario)
    document.addEventListener('pinky:open', start, { once: true });

    btn.addEventListener('click', () => {
      if (playing && !audio.paused) {
        audio.pause();
        playing = false;
        btn.classList.add('is-muted');
        btn.setAttribute('aria-pressed', 'false');
      } else {
        start();
      }
    });
  }
</script>
