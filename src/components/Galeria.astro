---
import { Image } from 'astro:assets';
import { fotos } from '../data/galeria.js';
import { contenido } from '../data/contenido.js';
const { galeria } = contenido;
---

<section class="galeria" id="galeria">
  <div class="galeria__head reveal">
    <h2 class="galeria__titulo">{galeria.titulo}</h2>
    <p class="galeria__sub">{galeria.subtitulo}</p>
  </div>

  <div class="galeria__grid">
    {
      fotos.map((foto, i) => (
        <button class="galeria__item reveal" data-index={i} aria-label={`Ampliar: ${foto.alt}`}>
          <Image
            src={foto.src}
            alt={foto.alt}
            widths={[400, 800, 1200]}
            sizes="(max-width: 600px) 90vw, (max-width: 1000px) 45vw, 30vw"
            loading="lazy"
          />
        </button>
      ))
    }
  </div>
</section>

<!-- Lightbox -->
<div class="lb" id="lightbox" aria-hidden="true">
  <button class="lb__close" aria-label="Cerrar">&times;</button>
  <button class="lb__nav lb__prev" aria-label="Anterior">&#8249;</button>
  <img class="lb__img" src="" alt="" />
  <button class="lb__nav lb__next" aria-label="Siguiente">&#8250;</button>
  <p class="lb__cap"></p>
</div>

<style>
  .galeria {
    padding: clamp(4rem, 12vw, 7rem) clamp(1rem, 4vw, 3rem);
    background: var(--ink);
  }
  .galeria__head {
    text-align: center;
    margin-bottom: 3rem;
  }
  .galeria__titulo {
    font-size: clamp(2rem, 7vw, 3rem);
    font-style: italic;
  }
  .galeria__sub {
    color: var(--rose);
    font-family: var(--script);
    font-size: clamp(1.3rem, 4vw, 1.8rem);
    margin-top: 0.3rem;
  }
  .galeria__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 250px), 1fr));
    grid-auto-rows: 1px;
    gap: 14px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .galeria__item {
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    background: var(--ink-soft);
    overflow: hidden;
    border-radius: 6px;
    grid-row-end: span 32;
    position: relative;
  }
  /* Damos altura variable para un look de mosaico editorial */
  .galeria__item:nth-child(3n + 1) { grid-row-end: span 40; }
  .galeria__item:nth-child(4n + 2) { grid-row-end: span 28; }
  .galeria__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease, filter 0.7s ease;
    filter: saturate(0.95);
  }
  .galeria__item:hover img,
  .galeria__item:focus-visible img {
    transform: scale(1.06);
    filter: saturate(1.1);
  }

  /* Lightbox */
  .lb {
    position: fixed;
    inset: 0;
    background: rgba(10, 7, 9, 0.96);
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
    padding: 1rem;
  }
  .lb.is-open {
    opacity: 1;
    pointer-events: auto;
  }
  .lb__img {
    max-width: 92vw;
    max-height: 82vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 20px 80px rgba(0, 0, 0, 0.6);
  }
  .lb__cap {
    position: absolute;
    bottom: 1.4rem;
    left: 0;
    right: 0;
    text-align: center;
    color: var(--cream-dim);
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.1rem;
    padding: 0 1rem;
  }
  .lb__close,
  .lb__nav {
    position: absolute;
    background: rgba(247, 240, 234, 0.08);
    border: 1px solid rgba(247, 240, 234, 0.18);
    color: var(--cream);
    cursor: pointer;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
    line-height: 1;
  }
  .lb__close:hover,
  .lb__nav:hover { background: rgba(232, 160, 180, 0.3); }
  .lb__close {
    top: 1.1rem;
    right: 1.1rem;
    width: 44px;
    height: 44px;
    font-size: 1.8rem;
  }
  .lb__nav {
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    font-size: 2rem;
  }
  .lb__prev { left: 1rem; }
  .lb__next { right: 1rem; }
  @media (max-width: 600px) {
    .lb__nav { width: 44px; height: 44px; font-size: 1.6rem; }
  }
</style>

<script>
  import { fotos } from '../data/galeria.js';

  const lb = document.getElementById('lightbox');
  if (lb) {
    const img = lb.querySelector<HTMLImageElement>('.lb__img')!;
    const cap = lb.querySelector<HTMLElement>('.lb__cap')!;
    const items = Array.from(document.querySelectorAll<HTMLElement>('.galeria__item'));
    let current = 0;

    function show(i: number) {
      current = (i + fotos.length) % fotos.length;
      const foto = fotos[current];
      // `src` puede ser un objeto de imagen de Astro o una cadena.
      const url = typeof foto.src === 'string' ? foto.src : foto.src.src;
      img.src = url;
      img.alt = foto.alt;
      cap.textContent = foto.alt;
    }
    function open(i: number) {
      show(i);
      lb!.classList.add('is-open');
      lb!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      lb!.classList.remove('is-open');
      lb!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    items.forEach((item, i) => item.addEventListener('click', () => open(i)));
    lb.querySelector('.lb__close')!.addEventListener('click', close);
    lb.querySelector('.lb__next')!.addEventListener('click', () => show(current + 1));
    lb.querySelector('.lb__prev')!.addEventListener('click', () => show(current - 1));
    lb.addEventListener('click', (e) => {
      if (e.target === lb) close();
    });
    document.addEventListener('keydown', (e) => {
      if (!lb.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowRight') show(current + 1);
      if (e.key === 'ArrowLeft') show(current - 1);
    });
  }
</script>
