---
import { contenido } from '../data/contenido.js';
const { intro } = contenido;
---

<div class="intro" id="intro">
  <div class="intro__inner">
    <p class="intro__pre">{intro.titulo}</p>
    <button class="envelope" id="open-btn" aria-label={intro.boton}>
      <span class="envelope__back"></span>
      <span class="envelope__letter"></span>
      <span class="envelope__flap"></span>
      <span class="envelope__front"></span>
      <span class="envelope__seal">♡</span>
    </button>
    <span class="intro__btn-label">{intro.boton}</span>
    <p class="intro__nota">{intro.nota}</p>
  </div>
</div>

<style>
  .intro {
    position: fixed;
    inset: 0;
    z-index: 80;
    background: radial-gradient(120% 120% at 50% 30%, var(--ink-soft) 0%, var(--ink) 70%);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 1s ease, visibility 1s ease;
    padding: 1.5rem;
  }
  .intro.is-gone {
    opacity: 0;
    visibility: hidden;
  }
  .intro__inner {
    text-align: center;
  }
  .intro__pre {
    font-family: var(--script);
    color: var(--rose);
    font-size: clamp(1.8rem, 6vw, 2.8rem);
    margin-bottom: 2rem;
  }
  .envelope {
    position: relative;
    width: 230px;
    height: 152px;
    margin: 0 auto;
    border: none;
    background: transparent;
    cursor: pointer;
    display: block;
    perspective: 800px;
    transition: transform 0.3s ease;
    animation: float 3.5s ease-in-out infinite;
  }
  .envelope:hover { transform: translateY(-4px) scale(1.03); }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .envelope span { position: absolute; }
  /* Cuerpo / fondo del sobre */
  .envelope__back {
    inset: 0;
    background: var(--rose-deep);
    border-radius: 10px;
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.4);
  }
  /* La carta blanca, oculta tras la solapa; sube al abrir */
  .envelope__letter {
    top: 12px;
    left: 16px;
    width: calc(100% - 32px);
    height: 88px;
    background: var(--cream);
    border-radius: 4px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.12);
    z-index: 2;
    transition: transform 0.6s ease 0.15s;
  }
  /* Bolsillo frontal (chevron hacia arriba) */
  .envelope__front {
    inset: 0;
    background: var(--rose);
    border-radius: 0 0 10px 10px;
    clip-path: polygon(0 100%, 0 36%, 50% 70%, 100% 36%, 100% 100%);
    z-index: 3;
  }
  /* Solapa superior (triángulo hacia abajo) que se abre */
  .envelope__flap {
    inset: 0;
    background: linear-gradient(150deg, var(--rose-deep) 0%, #b66a85 100%);
    clip-path: polygon(0 0, 100% 0, 50% 66%);
    border-radius: 10px 10px 0 0;
    transform-origin: top center;
    transition: transform 0.55s ease, z-index 0s linear 0.28s;
    z-index: 4;
    backface-visibility: hidden;
  }
  /* Sello de corazón, centrado en la punta de la solapa */
  .envelope__seal {
    top: 70px;
    left: 50%;
    transform: translateX(-50%);
    width: 38px;
    height: 38px;
    background: var(--gold);
    color: var(--ink);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.15rem;
    box-shadow: 0 3px 8px rgba(0, 0, 0, 0.25);
    z-index: 5;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  /* Estado abierto */
  .envelope.open .envelope__flap { transform: rotateX(-172deg); z-index: 1; }
  .envelope.open .envelope__seal { opacity: 0; transform: translateX(-50%) scale(0.6); }
  .envelope.open .envelope__letter { transform: translateY(-58px) scale(1.03); }

  .intro__btn-label {
    display: inline-block;
    margin-top: 2.2rem;
    font-family: var(--sans);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-size: 0.85rem;
    color: var(--cream);
    border: 1px solid rgba(247, 240, 234, 0.3);
    padding: 0.7rem 1.6rem;
    border-radius: 100px;
    transition: background 0.3s ease;
    pointer-events: none;
  }
  .intro__nota {
    margin-top: 1.6rem;
    color: var(--cream-dim);
    font-family: var(--serif);
    font-style: italic;
    font-size: 1rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .envelope { animation: none; }
  }
</style>

<script>
  import confetti from 'canvas-confetti';

  const intro = document.getElementById('intro');
  const btn = document.getElementById('open-btn');
  // Bloqueamos el scroll hasta que se abra el sobre.
  document.body.style.overflow = 'hidden';

  let opened = false;
  function abrir() {
    if (opened) return;
    opened = true;
    btn?.classList.add('open');

    // Confeti en tonos rosados/dorados
    const colors = ['#e8a0b4', '#c97b94', '#d9b88f', '#f7f0ea'];
    const burst = (originX: number) =>
      confetti({
        particleCount: 70,
        spread: 75,
        startVelocity: 45,
        origin: { x: originX, y: 0.7 },
        colors,
      });
    burst(0.5);
    setTimeout(() => { burst(0.2); burst(0.8); }, 180);
    setTimeout(() => confetti({ particleCount: 120, spread: 100, origin: { y: 0.6 }, colors }), 350);

    // Avisar a la música que puede empezar (gesto del usuario)
    document.dispatchEvent(new CustomEvent('pinky:open'));

    // Revelar la página
    setTimeout(() => {
      intro?.classList.add('is-gone');
      document.body.style.overflow = '';
    }, 1100);
  }

  btn?.addEventListener('click', abrir);
</script>
