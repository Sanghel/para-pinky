---
import { contenido } from '../data/contenido.js';
const { contador, juntosDesde } = contenido;
// Pasamos la fecha de inicio al cliente como timestamp.
const desde = juntosDesde.getTime();
---

<section class="contador">
  <div class="contador__inner reveal">
    <h2 class="contador__titulo">{contador.titulo}</h2>
    <div class="contador__grid" data-desde={desde}>
      <div class="contador__item">
        <span class="contador__num" data-dias>—</span>
        <span class="contador__label">días</span>
      </div>
      <div class="contador__item">
        <span class="contador__num" data-horas>—</span>
        <span class="contador__label">horas</span>
      </div>
      <div class="contador__item">
        <span class="contador__num" data-min>—</span>
        <span class="contador__label">minutos</span>
      </div>
      <div class="contador__item">
        <span class="contador__num" data-seg>—</span>
        <span class="contador__label">segundos</span>
      </div>
    </div>
    <p class="contador__pie">{contador.pie}</p>
  </div>
</section>

<style>
  .contador {
    padding: clamp(4rem, 12vw, 7rem) 1.5rem;
    text-align: center;
    background: var(--ink);
  }
  .contador__titulo {
    font-size: clamp(1.8rem, 6vw, 2.6rem);
    color: var(--rose);
    font-style: italic;
    margin-bottom: 2.5rem;
  }
  .contador__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(1rem, 5vw, 3rem);
  }
  .contador__item {
    display: flex;
    flex-direction: column;
    min-width: 4.5rem;
  }
  .contador__num {
    font-family: var(--serif);
    font-size: clamp(2.4rem, 9vw, 4.2rem);
    font-weight: 600;
    color: var(--cream);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .contador__label {
    font-size: 0.8rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--cream-dim);
    margin-top: 0.6rem;
  }
  .contador__pie {
    margin-top: 2.5rem;
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--cream-dim);
  }
</style>

<script>
  function pad(n: number) {
    return String(n).padStart(2, '0');
  }
  const grid = document.querySelector<HTMLElement>('.contador__grid');
  if (grid) {
    const desde = Number(grid.dataset.desde);
    const elDias = grid.querySelector<HTMLElement>('[data-dias]');
    const elHoras = grid.querySelector<HTMLElement>('[data-horas]');
    const elMin = grid.querySelector<HTMLElement>('[data-min]');
    const elSeg = grid.querySelector<HTMLElement>('[data-seg]');

    function tick() {
      let diff = Math.floor((Date.now() - desde) / 1000);
      const dias = Math.floor(diff / 86400);
      diff -= dias * 86400;
      const horas = Math.floor(diff / 3600);
      diff -= horas * 3600;
      const min = Math.floor(diff / 60);
      const seg = diff - min * 60;
      if (elDias) elDias.textContent = dias.toLocaleString('es');
      if (elHoras) elHoras.textContent = pad(horas);
      if (elMin) elMin.textContent = pad(min);
      if (elSeg) elSeg.textContent = pad(seg);
    }
    tick();
    setInterval(tick, 1000);
  }
</script>
